{
  "cli": {
    "version": ">= 16.0.0",
    "promptToInstall": true
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://aglugan-production.up.railway.app",
        "EXPO_PUBLIC_WS_URL": "wss://aglugan-production.up.railway.app/ws"
      }
    },
    "production": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://aglugan-production.up.railway.app",
        "EXPO_PUBLIC_WS_URL": "wss://aglugan-production.up.railway.app/ws"
      }
    }
  },
  "submit": {
    "production": {}
  }
}