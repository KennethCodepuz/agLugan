{
  "cli": {
    "version": ">= 16.0.0",
    "promptToInstall": true
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "http://YOUR_SERVER_IP:8080",
        "EXPO_PUBLIC_WS_URL": "ws://YOUR_SERVER_IP:8080/ws"
      }
    },
    "production": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "http://YOUR_SERVER_IP:8080",
        "EXPO_PUBLIC_WS_URL": "ws://YOUR_SERVER_IP:8080/ws"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
